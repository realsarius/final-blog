                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"featured\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/posts/{{adminPostId}}/featured",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "posts", "{{adminPostId}}", "featured"]
            }
          }
        },
        {
          "name": "PUT /api/admin/profile/author",
          "request": {
