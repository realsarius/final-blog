DATABASE_URL="postgresql://blog_dev:blog_dev_password@localhost:5438/blog_dev?schema=public"
DATABASE_TEST_URL="postgresql://blog_test:blog_test_password@localhost:5433/blog_test?schema=public"
DATABASE_PROD_URL="postgresql://blog_prod:blog_prod_password@localhost:5434/blog_prod?schema=public"

DATABASE_DEV_NAME="blog_dev"
DATABASE_DEV_USER="blog_dev"
DATABASE_DEV_PASSWORD="blog_dev_password"
DATABASE_DEV_PORT="5438"

DATABASE_TEST_NAME="blog_test"
DATABASE_TEST_USER="blog_test"
DATABASE_TEST_PASSWORD="blog_test_password"
DATABASE_TEST_PORT="5433"

DATABASE_PROD_NAME="blog_prod"
DATABASE_PROD_USER="blog_prod"
DATABASE_PROD_PASSWORD="blog_prod_password"
DATABASE_PROD_PORT="5434"

PGADMIN_DEFAULT_EMAIL="admin@finalblog.local"
PGADMIN_DEFAULT_PASSWORD="replace-me"

NEXTAUTH_URL="http://localhost:3007"
NEXTAUTH_SECRET="replace-me"
NEXT_PUBLIC_SITE_URL="http://localhost:3007"
NEXT_PUBLIC_SITE_NAME="Blog Adı"
LINKEDIN_URL=""
GITHUB_URL=""
REDIS_URL="redis://localhost:6381"
RATE_LIMIT_WINDOW_SEC="900"
RATE_LIMIT_MAX="5"
# Production ortamında yalnızca güvenilen reverse proxy varsa true yapın
RATE_LIMIT_TRUST_PROXY_HEADERS="false"
# x-forwarded-for | x-real-ip
RATE_LIMIT_PREFERRED_IP_HEADER="x-forwarded-for"
SECURITY_LOG_ENABLED="true"

# Upload storage: local | r2 | auto
UPLOAD_PROVIDER="local"
UPLOAD_REQUIRE_ADMIN="true"
UPLOAD_POST_REQUIRE_ADMIN="true"
UPLOAD_GET_REQUIRE_ADMIN="true"
UPLOAD_DELETE_REQUIRE_ADMIN="true"
UPLOAD_RATE_LIMIT_WINDOW_SEC="60"
UPLOAD_RATE_LIMIT_MAX="30"
# Production önerisi: UPLOAD_MALWARE_SCAN="clamav" ve UPLOAD_MALWARE_FAIL_OPEN="false"
UPLOAD_MALWARE_SCAN="off"
UPLOAD_MALWARE_FAIL_OPEN="false"
# Virgülle ayırarak ek origin tanımlayabilirsiniz. Ör: http://192.168.1.25:3007,http://localhost:5173
UPLOAD_CORS_ALLOWED_ORIGINS=""
# Geçici yerel ağ testinde true, production'da false önerilir.
UPLOAD_CORS_ALLOW_PRIVATE_NETWORK="false"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
CLAMAV_TIMEOUT_MS="8000"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
R2_ENDPOINT=""
R2_REGION="auto"

ADMIN_FIRST_NAME="Admin"
ADMIN_LAST_NAME="User"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-me"
